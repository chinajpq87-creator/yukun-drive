---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog — Technical Insights | Yukun" description="Technical articles on micro motor selection, drive system design, and application engineering for product developers.">
  <section class="section-padding">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <h1 class="text-4xl font-bold mb-4">Technical Blog</h1>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl">
          Engineering insights on micro drive selection, application design, and industry trends.
        </p>
      </div>

      <div class="text-center py-20">
        <p class="text-[var(--color-text-muted)] text-lg">Articles coming soon.</p>
        <p class="text-[var(--color-text-muted)] text-sm mt-2">Topics: Brushless vs Brushed · Smart Lock Motor Selection · Micro Pump Guide · EV Charging Actuators</p>
      </div>
    </div>
  </section>
</BaseLayout>
