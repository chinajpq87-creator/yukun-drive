---
// Yukun 首页 — 6 段式产品经理布局
// 1.Solutions 2.Applications 3.Motion Components 4.Why Yukun 5.Engineering Resources 6.Get Engineering Support
import BaseLayout from '../layouts/BaseLayout.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import { getCollection } from 'astro:content';

// ── 数据查询 ──
const solutions = await getCollection('solutions', ({ data }) => !data.draft);
const products = await getCollection('products', ({ data }) => !data.draft);
const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = blogPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// ── 方案元数据 (icon + short description) ──
const solutionMeta: Record<string, { icon: string; short: string; industries: string[] }> = {
  'smart-lock-micro-motor-solution': {
    icon: '🔐',
    short: 'Precision drives for fingerprint locks, electronic deadbolts, and hotel card lock systems.',
    industries: ['Smart Home', 'Security', 'Access Control'],
  },
  'ev-charging-gun-actuator-solution': {
    icon: '⚡',
    short: 'Self-locking worm gear actuators and micro switch assemblies for EV charging gun electronic locks.',
    industries: ['EV Infrastructure', 'Automotive', 'New Energy'],
  },
  'medical-device-micro-drive-solution': {
    icon: '🏥',
    short: 'Ultra-quiet BLDC motors and precision gear drives for ventilators, surgical robots, and IVD instruments.',
    industries: ['Medical', 'Lab Instruments', 'IVD'],
  },
  'smart-home-automation': {
    icon: '🏠',
    short: 'Compact, low-noise motors for motorized curtains, smart valves, adjustable furniture, and IoT devices.',
    industries: ['Smart Home', 'IoT', 'Consumer'],
  },
  'industrial-automation-drive': {
    icon: '🏭',
    short: 'Continuous-duty gear motors for valve controls, dispensers, and precision automation equipment.',
    industries: ['Industrial', 'Process Control', 'Valve Systems'],
  },
  'robotics-joint-actuator': {
    icon: '🤖',
    short: 'Low-backlash planetary gears for robot grippers, educational robots, and servo replacements.',
    industries: ['Robotics', 'Automation', 'Servo Systems'],
  },
};

// ── 应用场景分类 ──
const applicationCategories = [
  { icon: '🏥', name: 'Medical Devices', desc: 'Ventilators, infusion pumps, surgical robots, lab instruments', href: '/solutions/medical-device-micro-drive-solution' },
  { icon: '🔐', name: 'Smart Lock & Security', desc: 'Fingerprint locks, electronic deadbolts, access control systems', href: '/solutions/smart-lock-micro-motor-solution' },
  { icon: '⚡', name: 'EV & Automotive', desc: 'Charging gun actuators, HVAC flap actuators, mirror fold motors', href: '/solutions/ev-charging-gun-actuator-solution' },
  { icon: '🏭', name: 'Industrial Automation', desc: 'Valve controls, dispensers, small actuators, conveyor systems', href: '/solutions/industrial-automation-drive' },
  { icon: '🤖', name: 'Robotics', desc: 'Robot joints, grippers, educational robots, servo replacements', href: '/solutions/robotics-joint-actuator' },
  { icon: '🏠', name: 'Smart Home & IoT', desc: 'Motorized curtains, smart valves, adjustable furniture, connected devices', href: '/solutions/smart-home-automation' },
];

// ── 产品生态分类 ──
const productEcosystem = [
  {
    category: 'Micro DC Gear Motors',
    icon: '⚙️',
    desc: '1.2–5.0 N·m torque. Spur, planetary, and worm options. 12–35mm diameter.',
    items: ['N20 Spur (12mm)', 'N20 Planetary (12mm)', 'N20 Worm (12mm)', '370 Worm (24mm)', '520 Worm (35mm)'],
    href: '/products',
  },
  {
    category: 'Brushless DC Motors',
    icon: '🔵',
    desc: '15,000+ hr life. <30 dB noise. Zero cogging. Minimal EMI.',
    items: ['BL-24C Slotless (24mm)'],
    note: 'More sizes coming Q3 2026',
    href: '/products',
  },
  {
    category: 'Micro Pumps',
    icon: '💧',
    desc: 'Diaphragm and peristaltic micro pumps for medical and environmental applications.',
    items: [],
    note: 'Coming Q4 2026',
    href: '/solutions/medical-device-micro-drive-solution',
  },
  {
    category: 'Micro Switches',
    icon: '🔘',
    desc: 'Subminiature micro switches for position sensing and limit detection.',
    items: [],
    note: 'Coming Q4 2026',
    href: '/contact',
  },
];

// ── Featured 产品（首页精选） ──
const featuredSlugs = ['n20-metal-spur-gear-motor', 'n20-worm-self-locking-gear-motor', '370-worm-self-locking-gear-motor', 'bl-24c-slotless-bldc-motor'];
const featuredProducts = featuredSlugs
  .map((slug) => products.find((p) => p.data.slug === slug))
  .filter(Boolean);
---

<BaseLayout ogType="website">
  <!-- ═══════════════════════════════════════════════ -->
  <!-- HERO -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-gradient-to-b from-[var(--color-bg-primary)] to-[var(--color-bg-secondary)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 text-xs px-3 py-1.5 bg-[var(--color-brand)]/10 text-[var(--color-brand-light)] rounded-full font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-[var(--color-accent-green)]"></span>
          Engineering-Led Selection · Supply Coordination · Global Customer Support
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
          Micro Motion.<br />
          <span class="text-[var(--color-brand-light)]">Engineered for Your Product.</span>
        </h1>
        <p class="text-xl text-[var(--color-text-secondary)] mb-8 max-w-2xl leading-relaxed">
          From smart locks to surgical robots — precision micro gear motors, BLDC motors, and micro pumps. Engineering-led product selection and supply coordination for global teams.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/products" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-[var(--color-brand)] hover:bg-[var(--color-brand-light)] rounded-lg transition-colors shadow-lg shadow-[var(--color-brand)]/20">
            Browse Motion Components →
          </a>
          <a href="/solutions" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-medium text-[var(--color-text-primary)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-lg transition-colors hover:bg-[var(--color-bg-card)]">
            Explore by Application →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 1️⃣ SOLUTIONS · 解决方案 -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="bg-[var(--color-bg-secondary)] border-y border-[var(--color-border-default)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center mb-12">
        <span class="text-xs font-semibold text-[var(--color-brand-light)] uppercase tracking-widest">Solutions</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Application-Specific Drive Solutions</h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
          We don't just sell motors — we solve motion problems. Each solution is pre-engineered for your industry's specific torque, noise, life, and compliance requirements.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {solutions.map((s) => {
          const meta = solutionMeta[s.data.slug];
          return (
            <a
              href={`/solutions/${s.data.slug}`}
              class="group block bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:shadow-[var(--color-brand)]/5"
            >
              {meta && (
                <>
                  <div class="flex items-center gap-3 mb-4">
                    <span class="text-3xl">{meta.icon}</span>
                    <div>
                      <h3 class="font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-brand-light)] transition-colors">
                        {s.data.title?.split('|')[0]?.trim() ?? s.data.title}
                      </h3>
                    </div>
                  </div>
                  <p class="text-sm text-[var(--color-text-secondary)] mb-4 leading-relaxed">{meta.short}</p>
                  <div class="flex flex-wrap gap-1.5">
                    {meta.industries.map((ind) => (
                      <span class="text-[10px] px-2 py-0.5 bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)] rounded-full">{ind}</span>
                    ))}
                  </div>
                </>
              )}
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 2️⃣ APPLICATIONS · 应用场景 -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-12">
      <span class="text-xs font-semibold text-[var(--color-brand-light)] uppercase tracking-widest">Applications</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Where Yukun Drives Are at Work</h2>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        From life-critical medical devices to millions of smart locks — our micro drives power products across every major industry.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {applicationCategories.map((app) => (
        <a
          href={app.href}
          class="group flex items-start gap-4 bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl p-5 transition-all duration-300 hover:shadow-md hover:shadow-[var(--color-brand)]/5"
        >
          <span class="text-3xl flex-shrink-0 mt-0.5">{app.icon}</span>
          <div>
            <h3 class="font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-brand-light)] transition-colors mb-1">
              {app.name}
            </h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{app.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 3️⃣ MOTION COMPONENTS · 核心产品生态 -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="bg-[var(--color-bg-secondary)] border-y border-[var(--color-border-default)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center mb-12">
        <span class="text-xs font-semibold text-[var(--color-brand-light)] uppercase tracking-widest">Motion Components</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Core Product Ecosystem</h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
          A growing platform of micro drive components — from the essential gear motor families to expanding pump and switch lines.
        </p>
      </div>

      <!-- Product category cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        {productEcosystem.map((eco) => (
          <a
            href={eco.href}
            class="block bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl p-6 transition-all duration-300 hover:shadow-md hover:shadow-[var(--color-brand)]/5"
          >
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">{eco.icon}</span>
              <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">{eco.category}</h3>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] mb-4 leading-relaxed">{eco.desc}</p>
            {eco.items.length > 0 ? (
              <div class="flex flex-wrap gap-1.5 mb-3">
                {eco.items.map((item) => (
                  <span class="text-[11px] px-2 py-0.5 bg-[var(--color-bg-elevated)] text-[var(--color-brand-light)] rounded-full font-mono">{item}</span>
                ))}
              </div>
            ) : null}
            {eco.note && (
              <span class="text-xs text-[var(--color-text-muted)] italic">{eco.note}</span>
            )}
          </a>
        ))}
      </div>

      <!-- Featured products row -->
      {featuredProducts.length > 0 && (
        <div>
          <h3 class="text-xl font-bold text-center mb-6">Engineer Favorites</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {featuredProducts.map((p) => (
              <a
                href={`/products/${p.data.slug}`}
                class="group block bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl p-5 transition-all duration-300 hover:shadow-md hover:shadow-[var(--color-brand)]/5"
              >
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs px-2 py-0.5 bg-[var(--color-brand)]/10 text-[var(--color-brand-light)] rounded-full font-medium">
                    {p.data.sub_category}
                  </span>
                  <span class="text-[11px] text-[var(--color-text-muted)] font-mono">{p.data.product_code}</span>
                </div>
                <h4 class="font-semibold text-sm text-[var(--color-text-primary)] group-hover:text-[var(--color-brand-light)] transition-colors mb-2 line-clamp-2">
                  {p.data.title?.split('|')[0]?.trim() ?? p.data.title}
                </h4>
                <p class="text-xs text-[var(--color-text-secondary)] line-clamp-2 mb-3">{p.data.meta_description}</p>
                <span class="text-sm font-semibold text-[var(--color-accent-green)]">Pricing confirmed on inquiry</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 4️⃣ WHY YUKUN · 供应链能力 -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-12">
      <span class="text-xs font-semibold text-[var(--color-brand-light)] uppercase tracking-widest">Why Yukun</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Engineering Support. Supply Coordination.</h2>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        A practical bridge between your application requirements and established manufacturing partners.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-xl p-6">
        <div class="text-2xl mb-3">🏭</div>
        <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">Manufacturing Partner Network</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Access established manufacturing partners for micro-motion components without managing multiple sourcing relationships.</p>
      </div>

      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-xl p-6">
        <div class="text-2xl mb-3">⚡</div>
        <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">Application-Focused Selection</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Share your requirements and receive component options aligned with torque, speed, size, noise, and integration constraints.</p>
      </div>

      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-xl p-6">
        <div class="text-2xl mb-3">🔧</div>
        <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">Custom Requirement Coordination</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Coordinate shaft, connector, encoder, mounting, and packaging requirements with the appropriate manufacturing partner.</p>
      </div>

      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-xl p-6">
        <div class="text-2xl mb-3">✅</div>
        <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">Quality Document Coordination</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Coordinate available drawings, specifications, and quality documents required for your evaluation process.</p>
      </div>

      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-xl p-6">
        <div class="text-2xl mb-3">🌍</div>
        <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">Logistics &amp; Order Follow-Up</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Coordinate shipping options, export documentation, and order progress after quotation details are confirmed.</p>
      </div>

      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-xl p-6">
        <div class="text-2xl mb-3">🎯</div>
        <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">Engineer-Led Communication</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Discuss application requirements in practical engineering terms before product, availability, lead time, and commercial terms are confirmed for your inquiry.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 5️⃣ ENGINEERING RESOURCES · 技术资源 -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="bg-[var(--color-bg-secondary)] border-y border-[var(--color-border-default)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center mb-12">
        <span class="text-xs font-semibold text-[var(--color-brand-light)] uppercase tracking-widest">Engineering Resources</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Tools & Knowledge for Your Design Process</h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
          Selection guides, technical comparisons, teardowns, and engineering deep dives — all written by engineers, for engineers.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
        <!-- Resource highlight -->
        <a href="/resources" class="group block lg:col-span-1 bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl p-6 transition-all duration-300 hover:shadow-md hover:shadow-[var(--color-brand)]/5">
          <div class="text-2xl mb-3">📖</div>
          <span class="text-xs px-2 py-0.5 bg-[var(--color-brand)]/10 text-[var(--color-brand-light)] rounded-full font-medium">Selection Guide</span>
          <h3 class="font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-brand-light)] transition-colors mt-3 mb-2">
            How to Select Micro Gear Motors
          </h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
            Define torque, speed, and constraints → choose gear type → select ratio → optimize for your application. Complete engineer's checklist.
          </p>
          <span class="text-sm font-medium text-[var(--color-brand-light)] group-hover:translate-x-1 transition-transform inline-block">Read Guide →</span>
        </a>

        <!-- Blog posts -->
        <div class="lg:col-span-2 space-y-4">
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-4">Latest from the Engineering Blog</h3>
          {latestPosts.length > 0 ? (
            latestPosts.map((post) => (
              <a
                href={`/blog/${post.data.slug}`}
                class="group block bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl p-5 transition-all duration-300"
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="text-xs px-2 py-0.5 bg-[var(--color-brand)]/10 text-[var(--color-brand-light)] rounded-full font-medium">{post.data.category}</span>
                      {post.data.date && (
                        <span class="text-xs text-[var(--color-text-muted)]">
                          {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                        </span>
                      )}
                    </div>
                    <h4 class="font-semibold text-sm text-[var(--color-text-primary)] group-hover:text-[var(--color-brand-light)] transition-colors line-clamp-1">
                      {post.data.title?.split('|')[0]?.trim()}
                    </h4>
                    <p class="text-xs text-[var(--color-text-secondary)] mt-1 line-clamp-1">{post.data.meta_description}</p>
                  </div>
                  <span class="text-[var(--color-text-muted)] group-hover:text-[var(--color-brand-light)] group-hover:translate-x-1 transition-all flex-shrink-0 mt-1">→</span>
                </div>
              </a>
            ))
          ) : (
            <p class="text-sm text-[var(--color-text-muted)]">No blog posts yet. Check back soon.</p>
          )}
          <a href="/blog" class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-brand-light)] hover:text-[var(--color-brand)] transition-colors mt-2">
            View All Posts →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 6️⃣ GET ENGINEERING SUPPORT · 询盘入口 -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="bg-gradient-to-br from-[var(--color-bg-card)] to-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-2xl p-10 md:p-16">
      <div class="max-w-3xl mx-auto text-center">
        <span class="text-xs font-semibold text-[var(--color-brand-light)] uppercase tracking-widest">Get Engineering Support</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Ready to Power Your Product?</h2>
        <p class="text-lg text-[var(--color-text-secondary)] mb-10 leading-relaxed">
          Tell us your application requirements. We coordinate product options, availability, lead time, and commercial details with the appropriate manufacturing partner for each inquiry.
        </p>

        <!-- How it works -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
          {[
            { step: '01', label: 'Share Your Application', icon: '📝' },
            { step: '02', label: 'Review Product Options', icon: '📐' },
            { step: '03', label: 'Confirm Availability & Lead Time', icon: '📦' },
            { step: '04', label: 'Coordinate Your Order', icon: '🚀' },
          ].map((s) => (
            <div class="text-center">
              <div class="text-2xl mb-2">{s.icon}</div>
              <div class="text-[10px] font-bold text-[var(--color-text-muted)] mb-1">{s.step}</div>
              <p class="text-xs text-[var(--color-text-secondary)] leading-snug">{s.label}</p>
            </div>
          ))}
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/contact" class="inline-flex items-center justify-center px-10 py-4 text-base font-semibold text-white bg-[var(--color-brand)] hover:bg-[var(--color-brand-light)] rounded-lg transition-colors shadow-lg shadow-[var(--color-brand)]/20">
