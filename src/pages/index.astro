---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import ProductCard from '../components/ProductCard.astro';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');

const featuredProductSlugs = [
  'n20-metal-spur-gear-motor',
  'n20-worm-self-locking-gear-motor',
  '370-worm-self-locking-gear-motor',
  'bl-24c-slotless-bldc-motor',
];

const featuredProducts = featuredProductSlugs
  .map((slug) => products.find((p) => p.data.slug === slug))
  .filter(Boolean);

const solutionIcons: Record<string, string> = {
  'smart-lock-micro-motor-solution': '🔐',
  'ev-charging-gun-actuator-solution': '⚡',
  'medical-device-micro-drive-solution': '🏥',
  'smart-home-automation': '🏠',
  'industrial-automation-drive': '🏭',
  'environmental-monitoring-pump': '🌿',
  'robotics-joint-actuator': '🤖',
  'water-treatment-fluid-control': '💧',
};

const solutionLabels: Record<string, string> = {
  'smart-lock-micro-motor-solution': 'Smart Lock Drives',
  'ev-charging-gun-actuator-solution': 'EV Charging Actuators',
  'medical-device-micro-drive-solution': 'Medical Device Drives',
  'smart-home-automation': 'Smart Home Automation',
  'industrial-automation-drive': 'Industrial Automation',
  'environmental-monitoring-pump': 'Environmental Monitoring',
  'robotics-joint-actuator': 'Robotics & Joints',
  'water-treatment-fluid-control': 'Water Treatment',
};
---

<BaseLayout ogType="website">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
          Precision Micro Drives.<br />
          <span class="text-[var(--color-brand-light)]">From Concept to Production.</span>
        </h1>
        <p class="text-xl text-[var(--color-text-secondary)] mb-8 max-w-2xl">
          Micro gear motors, BLDC motors, micro pumps, and switches — engineered for medical devices, smart locks, EV charging, robotics, and industrial automation. 1-week samples, FOB Shenzhen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/products" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-[var(--color-brand)] hover:bg-[var(--color-brand-light)] rounded-lg transition-colors shadow-lg shadow-[var(--color-brand)]/20">
            Browse Products →
          </a>
          <a href="/solutions" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-medium text-[var(--color-text-primary)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-lg transition-colors">
            View by Application →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  {featuredProducts.length > 0 && (
    <section class="bg-[var(--color-bg-secondary)] border-y border-[var(--color-border-default)]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Featured Products</h2>
        <p class="text-[var(--color-text-secondary)] mb-8">Engineered for demanding applications. Available in 1 week.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {featuredProducts.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Solutions Grid -->
  <section class="section-padding">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Solutions by Application</h2>
      <p class="text-[var(--color-text-secondary)] mb-8">We don't just sell motors — we solve motion problems for your specific industry.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {Object.entries(solutionLabels).map(([slug, label]) => (
          <a
            href={`/solutions/${slug}`}
            class="group block bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl p-5 transition-all duration-300"
          >
            <div class="text-2xl mb-3">{solutionIcons[slug] ?? '📐'}</div>
            <h3 class="font-semibold text-sm text-[var(--color-text-primary)] group-hover:text-[var(--color-brand-light)] transition-colors">
              {label}
            </h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    title="Ready to Find Your Micro Drive Solution?"
    subtitle="Tell us your application and our engineering team will recommend the optimal motor, gear ratio, and custom options. Samples ship in 1 week."
    primaryLabel="Request Engineering Consultation →"
    primaryHref="/contact"
    secondaryLabel="Browse All Products"
    secondaryHref="/products"
  />

  <!-- Structured Data -->
  <OrganizationSchema slot="structured-data" />
</BaseLayout>
