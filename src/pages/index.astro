---
import ContactCta from '../components/ContactCta.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="OPC Motion Solutions | Smart Product Engineering">
  <section class="hero">
    <p class="eyebrow">OPC AI Motion Solution Platform</p>
    <h1>We solve motion challenges for smart products.</h1>
    <p class="hero-copy">From customer application needs to component-level Motion Solutions for smart home, pet devices, personal care, haptics, and robotics.</p>
    <div class="hero-actions">
      <a class="button" href="/solutions">Explore Solutions</a>
      <a class="button button-secondary" href="/components">Browse Components</a>
    </div>
  </section>
  <section class="section-grid">
    <article><p class="eyebrow">01</p><h2>Market-led design</h2><p>Start from the application, customer problem, and motion requirement.</p></article>
    <article><p class="eyebrow">02</p><h2>Component integration</h2><p>Build clear, reusable component BOMs for each Motion Solution.</p></article>
    <article><p class="eyebrow">03</p><h2>Engineering support</h2><p>Align product requirements before prototype and customization decisions.</p></article>
  </section>
  <ContactCta />
</BaseLayout>
