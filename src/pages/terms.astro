---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Use | Yukun" noIndex={true}>
  <section class="section-padding">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl font-bold mb-8">Terms of Use</h1>
      <div class="prose prose-invert max-w-none text-[var(--color-text-secondary)] space-y-4">
        <p><strong>Last updated:</strong> July 2026</p>

        <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">1. Acceptance of Terms</h2>
        <p>By accessing and using this website, you agree to be bound by these Terms of Use.</p>

        <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">2. Website Content</h2>
        <p>Product specifications, pricing, and lead times shown on this website are for reference purposes. Final specifications, pricing, and delivery terms will be confirmed in the official quotation and purchase order.</p>

        <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">3. Intellectual Property</h2>
        <p>All content on this website — including text, graphics, product descriptions, and technical data — is the property of Yukun (Shenzhen) Supply Chain Technology Co., Ltd. unless otherwise noted.</p>

        <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">4. Limitation of Liability</h2>
        <p>Yukun shall not be liable for any indirect, incidental, or consequential damages arising from the use of this website or the information contained herein.</p>

        <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">5. Governing Law</h2>
        <p>These terms are governed by the laws of the People's Republic of China.</p>

        <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">6. Contact</h2>
        <p>For questions about these terms, contact us at <a href="mailto:info@yukun-drive.com" class="text-[var(--color-brand-light)]">info@yukun-drive.com</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
