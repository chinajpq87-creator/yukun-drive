---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');

// Group by category
const grouped = products.reduce(
  (acc, p) => {
    const cat = p.data.category || 'Other';
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(p);
    return acc;
  },
  {} as Record<string, typeof products>
);
---

<BaseLayout title="Products — Micro Motors, Pumps & Switches | Yukun" description="Browse our complete line of micro DC gear motors, BLDC motors, micro pumps, and micro switches. Datasheets, CAD files, and samples available.">
  <section class="section-padding">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <h1 class="text-4xl font-bold mb-4">Products</h1>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl">
          Browse our complete line of micro drive components. Every product includes
          detailed specifications, performance data, CAD drawings, and customization options.
        </p>
      </div>

      {products.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-[var(--color-text-muted)] text-lg">Product pages coming soon.</p>
          <a href="/contact" class="inline-block mt-4 text-[var(--color-brand-light)] hover:text-[var(--color-brand)] font-medium">
            Request product information →
          </a>
        </div>
      ) : (
        Object.entries(grouped).map(([category, items]) => (
          <div class="mb-12">
            <h2 class="text-2xl font-bold mb-6 pb-2 border-b border-[var(--color-border-default)]">
              {category}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {items.map((p) => (
                <a
                  href={`/products/${p.data.slug}`}
                  class="group block bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl p-6 transition-all duration-300"
                >
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-xs px-2 py-0.5 bg-[var(--color-brand)]/20 text-[var(--color-brand-light)] rounded-full font-medium">
                      {p.data.sub_category}
                    </span>
                    <span class="text-xs text-[var(--color-text-muted)] tech-mono">{p.data.product_code}</span>
                  </div>
                  <h3 class="font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-brand-light)] transition-colors mb-2">
                    {p.data.title?.split('|')[0]?.trim()}
                  </h3>
                  <p class="text-sm text-[var(--color-text-secondary)] line-clamp-2">
                    {p.data.meta_description}
                  </p>
                </a>
              ))}
            </div>
          </div>
        ))
      )}
    </div>
  </section>
</BaseLayout>
