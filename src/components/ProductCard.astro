---
export interface Props {
  title: string;
  slug: string;
  description?: string;
  category?: string;
  specs?: string;
  price?: string;
  image?: string;
}

const { title, slug, description, category, specs, price, image } = Astro.props;
---

<a
  href={`/products/${slug}`}
  class="group block bg-[var(--color-bg-card)] border border-[var(--color-border-default)] hover:border-[var(--color-brand)] rounded-xl overflow-hidden transition-all duration-300 hover:shadow-lg hover:shadow-[var(--color-brand)]/5"
>
  <div class="aspect-[4/3] bg-[var(--color-bg-elevated)] flex items-center justify-center">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover" />
    ) : (
      <div class="text-center p-6">
        <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-[var(--color-bg-secondary)] flex items-center justify-center">
          <span class="text-2xl">⚙️</span>
        </div>
        {category && <span class="text-xs text-[var(--color-brand-light)] font-medium">{category}</span>}
      </div>
    )}
  </div>
  <div class="p-4">
    <h3 class="font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-brand-light)] transition-colors mb-1 line-clamp-2">
      {title}
    </h3>
    {description && (
      <p class="text-sm text-[var(--color-text-secondary)] line-clamp-2 mb-2">{description}</p>
    )}
    <div class="flex items-center justify-between mt-3">
      {specs && <span class="text-xs text-[var(--color-text-muted)] tech-mono">{specs}</span>}
      {price && (
        <span class="text-sm font-semibold text-[var(--color-accent-green)]">FOB {price}</span>
      )}
    </div>
  </div>
</a>
