---
// Base layout — used by all pages
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../utils/seo';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  // GEO / SEO enhanced props
  canonicalURL?: string;
  ogType?: string;
  ogImage?: string;
  twitterCard?: 'summary' | 'summary_large_image';
  noIndex?: boolean;
}

const {
  title,
  description,
  image,
  canonicalURL,
  ogType = 'website',
  ogImage,
  twitterCard = 'summary_large_image',
  noIndex = false,
} = Astro.props;

const pageTitle = title ?? `${SITE.name} — Micro Motion Solutions for Your Product`;
const pageDescription = description ?? SITE.description;
const pageImage = ogImage ?? image ?? `${SITE.url}${SITE.ogImage}`;
const pageUrl = canonicalURL ?? new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for faster font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts: Inter (body) + JetBrains Mono (tech specs) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <!-- Robots -->
    {noIndex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    {pageImage && (
      <>
        <meta property="og:image" content={pageImage} />
        <meta property="og:image:width" content={String(SITE.ogImageWidth)} />
        <meta property="og:image:height" content={String(SITE.ogImageHeight)} />
      </>
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {pageImage && <meta name="twitter:image" content={pageImage} />}

    <!-- PWA / Theme -->
    <meta name="theme-color" content={SITE.themeColor} />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />

    <!-- Google Search Console verification -->
    <meta name="google-site-verification" content="OlL2ilfOl1Uht3fN3s1Ld-SCh5lJJuTl91oDB1c8YL8" />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TF923QKFYJ"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-TF923QKFYJ');
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--color-bg-primary)] text-[var(--color-text-primary)]">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Structured Data slot — inject JSON-LD scripts from child pages -->
    <slot name="structured-data" />
  </body>
</html>
